<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Release builds trust only the platform system store. -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <!-- Ignored by release builds; used only when android:debuggable is true. -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
