# Copy to .env outside version control and replace values locally.
LVA_BIND_HOST=127.0.0.1
LVA_BIND_PORT=8765
LVA_DATABASE_URL=postgresql+asyncpg://local_voice_agent:CHANGE_ME@127.0.0.1:5432/local_voice_agent
LVA_PAIRING_TOKEN=CHANGE_ME
LVA_VOICE_ENABLED=0
LVA_AUDIO_WORKER_TOKEN=CHANGE_ME
LVA_STT_SOCKET=/home/kutae/.local/share/local-voice-agent/run/stt.sock
LVA_TTS_SOCKET=/home/kutae/.local/share/local-voice-agent/run/tts.sock
LVA_VLLM_API_KEY=CHANGE_ME
LVA_VLLM_BASE_URL=http://127.0.0.1:8766/v1
LVA_VLLM_MODEL=gemma4-12b
LVA_VLLM_PORT=8766
LVA_VLLM_STARTUP_TIMEOUT_SECONDS=360
LVA_MODEL_ROOT=E:\AI\Models\Standalone\LocalVoiceAgent
LVA_RUNTIME_ROOT=E:\Data\LocalVoiceAgent\runtime
LVA_CACHE_ROOT=E:\Cache\LocalVoiceAgent
# HF_TOKEN is not currently required for the selected ungated Gemma 4 repos.
# HF_TOKEN=
