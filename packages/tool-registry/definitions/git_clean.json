{
  "schema_version": "1.0",
  "name": "git_clean",
  "description": "Delete exactly previewed untracked files; Level 3 and denied by default.",
  "risk_level": 3,
  "timeout_seconds": 120,
  "idempotency": "required",
  "parameters": {
    "type": "object",
    "required": [
      "workspace_id",
      "expected_head",
      "preview_fingerprint",
      "include_ignored",
      "approval_id",
      "idempotency_key"
    ],
    "properties": {
      "workspace_id": {"type": "string", "minLength": 1},
      "expected_head": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
      "preview_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
      "include_ignored": {"const": false},
      "approval_id": {"type": "string", "format": "uuid"},
      "idempotency_key": {"type": "string", "format": "uuid"}
    },
    "additionalProperties": false
  }
}
