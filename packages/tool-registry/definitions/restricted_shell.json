{
  "schema_version": "1.0",
  "name": "restricted_shell",
  "description": "Run one allowlisted non-elevated executable with exact displayed arguments; disabled by default.",
  "risk_level": 2,
  "timeout_seconds": 300,
  "idempotency": "required",
  "parameters": {
    "type": "object",
    "required": [
      "workspace_id",
      "executable_id",
      "arguments",
      "environment_profile_id",
      "timeout_seconds",
      "approval_id",
      "idempotency_key"
    ],
    "properties": {
      "workspace_id": {"type": "string", "minLength": 1},
      "executable_id": {"type": "string", "minLength": 1, "maxLength": 128},
      "arguments": {
        "type": "array",
        "maxItems": 64,
        "items": {"type": "string", "maxLength": 4096}
      },
      "environment_profile_id": {"type": "string", "minLength": 1, "maxLength": 128},
      "timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 300},
      "max_output_bytes": {
        "type": "integer",
        "minimum": 1,
        "maximum": 1048576,
        "default": 262144
      },
      "approval_id": {"type": "string", "format": "uuid"},
      "idempotency_key": {"type": "string", "format": "uuid"}
    },
    "additionalProperties": false
  }
}
