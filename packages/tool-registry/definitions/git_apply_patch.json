{
  "schema_version": "1.0",
  "name": "git_apply_patch",
  "description": "Apply a bounded textual Git patch after exact worktree precondition checks.",
  "risk_level": 1,
  "timeout_seconds": 60,
  "idempotency": "required",
  "parameters": {
    "type": "object",
    "required": [
      "workspace_id",
      "expected_head",
      "expected_worktree_fingerprint",
      "patch",
      "idempotency_key"
    ],
    "properties": {
      "workspace_id": {"type": "string", "minLength": 1},
      "expected_head": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
      "expected_worktree_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
      "patch": {"type": "string", "minLength": 1, "maxLength": 1048576},
      "idempotency_key": {"type": "string", "format": "uuid"}
    },
    "additionalProperties": false
  }
}
