{
  "schema_version": "1.0",
  "name": "list_recent_files",
  "description": "List recently modified files inside an allowed workspace.",
  "risk_level": 0,
  "timeout_seconds": 20,
  "idempotency": "read_only",
  "parameters": {
    "type": "object",
    "required": ["workspace_id"],
    "properties": {
      "workspace_id": {
        "type": "string",
        "minLength": 1
      },
      "relative_path": {
        "type": "string",
        "maxLength": 1024,
        "default": "."
      },
      "within_minutes": {
        "type": "integer",
        "minimum": 1,
        "maximum": 525600,
        "default": 10080
      },
      "limit": {
        "type": "integer",
        "minimum": 1,
        "maximum": 500,
        "default": 100
      }
    },
    "additionalProperties": false
  }
}
