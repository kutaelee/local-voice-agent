{
  "schema_version": "1.0",
  "name": "git_log",
  "description": "Read a bounded Git commit history from a registered repository.",
  "risk_level": 0,
  "timeout_seconds": 20,
  "idempotency": "read_only",
  "parameters": {
    "type": "object",
    "required": ["workspace_id"],
    "properties": {
      "workspace_id": {
        "type": "string",
        "minLength": 1
      },
      "revision": {
        "type": "string",
        "minLength": 1,
        "maxLength": 256,
        "default": "HEAD"
      },
      "max_count": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100,
        "default": 20
      }
    },
    "additionalProperties": false
  }
}
