{
  "schema_version": "1.0",
  "name": "git_rebase",
  "description": "Rebase a clean local branch onto an exact commit after per-execution approval.",
  "risk_level": 2,
  "timeout_seconds": 300,
  "idempotency": "required",
  "parameters": {
    "type": "object",
    "required": [
      "workspace_id",
      "expected_head",
      "onto_commit",
      "require_clean_worktree",
      "approval_id",
      "idempotency_key"
    ],
    "properties": {
      "workspace_id": {"type": "string", "minLength": 1},
      "expected_head": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
      "onto_commit": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
      "require_clean_worktree": {"const": true},
      "approval_id": {"type": "string", "format": "uuid"},
      "idempotency_key": {"type": "string", "format": "uuid"}
    },
    "additionalProperties": false
  }
}
