{
  "schema_version": "1.0",
  "name": "rollback_file_change",
  "description": "Restore one exact executor backup after current-hash verification.",
  "risk_level": 1,
  "timeout_seconds": 30,
  "idempotency": "required",
  "parameters": {
    "type": "object",
    "required": [
      "workspace_id",
      "relative_path",
      "backup_id",
      "expected_current_sha256",
      "idempotency_key"
    ],
    "properties": {
      "workspace_id": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128
      },
      "relative_path": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1024
      },
      "backup_id": {
        "type": "string",
        "format": "uuid"
      },
      "expected_current_sha256": {
        "type": "string",
        "pattern": "^[a-f0-9]{64}$"
      },
      "idempotency_key": {
        "type": "string",
        "format": "uuid"
      }
    },
    "additionalProperties": false
  }
}
