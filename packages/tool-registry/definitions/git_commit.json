{
  "schema_version": "1.0",
  "name": "git_commit",
  "description": "Create one local commit from the exact reviewed index after per-execution approval.",
  "risk_level": 2,
  "timeout_seconds": 60,
  "idempotency": "required",
  "parameters": {
    "type": "object",
    "required": [
      "workspace_id",
      "expected_head",
      "expected_index_fingerprint",
      "message",
      "approval_id",
      "idempotency_key"
    ],
    "properties": {
      "workspace_id": {"type": "string", "minLength": 1},
      "expected_head": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
      "expected_index_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
      "message": {"type": "string", "minLength": 1, "maxLength": 4096},
      "approval_id": {"type": "string", "format": "uuid"},
      "idempotency_key": {"type": "string", "format": "uuid"}
    },
    "additionalProperties": false
  }
}
