{
  "schema_version": "1.0",
  "name": "run_linter",
  "description": "Run a registered workspace lint profile without accepting arbitrary flags.",
  "risk_level": 1,
  "timeout_seconds": 1800,
  "idempotency": "required",
  "parameters": {
    "type": "object",
    "required": ["workspace_id", "profile_id", "idempotency_key"],
    "properties": {
      "workspace_id": {"type": "string", "minLength": 1},
      "profile_id": {"type": "string", "minLength": 1, "maxLength": 128},
      "idempotency_key": {"type": "string", "format": "uuid"}
    },
    "additionalProperties": false
  }
}
