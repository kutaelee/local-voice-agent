{
  "schema_version": "1.0",
  "name": "git_reset",
  "description": "Destructively hard-reset to an exact commit; Level 3 and denied by default.",
  "risk_level": 3,
  "timeout_seconds": 120,
  "idempotency": "required",
  "parameters": {
    "type": "object",
    "required": [
      "workspace_id",
      "expected_head",
      "target_commit",
      "mode",
      "approval_id",
      "idempotency_key"
    ],
    "properties": {
      "workspace_id": {"type": "string", "minLength": 1},
      "expected_head": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
      "target_commit": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
      "mode": {"const": "hard"},
      "approval_id": {"type": "string", "format": "uuid"},
      "idempotency_key": {"type": "string", "format": "uuid"}
    },
    "additionalProperties": false
  }
}
