{
  "schema_version": "1.0",
  "name": "stop_dev_server",
  "description": "Stop only a development server previously started and tracked by this executor.",
  "risk_level": 1,
  "timeout_seconds": 60,
  "idempotency": "required",
  "parameters": {
    "type": "object",
    "required": ["workspace_id", "process_handle", "idempotency_key"],
    "properties": {
      "workspace_id": {"type": "string", "minLength": 1},
      "process_handle": {"type": "string", "format": "uuid"},
      "idempotency_key": {"type": "string", "format": "uuid"}
    },
    "additionalProperties": false
  }
}
