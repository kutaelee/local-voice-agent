{
  "schema_version": "1.0",
  "name": "git_merge",
  "description": "Fast-forward the current branch to an exact registered local commit after approval.",
  "risk_level": 2,
  "timeout_seconds": 120,
  "idempotency": "required",
  "parameters": {
    "type": "object",
    "required": [
      "workspace_id",
      "expected_head",
      "source_commit",
      "fast_forward_only",
      "approval_id",
      "idempotency_key"
    ],
    "properties": {
      "workspace_id": {"type": "string", "minLength": 1},
      "expected_head": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
      "source_commit": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
      "fast_forward_only": {"const": true},
      "approval_id": {"type": "string", "format": "uuid"},
      "idempotency_key": {"type": "string", "format": "uuid"}
    },
    "additionalProperties": false
  }
}
