{
  "schema_version": "1.0",
  "name": "calculate_hash",
  "description": "Calculate SHA-256 for one file inside an allowed workspace.",
  "risk_level": 0,
  "timeout_seconds": 300,
  "idempotency": "read_only",
  "parameters": {
    "type": "object",
    "required": ["workspace_id", "relative_path"],
    "properties": {
      "workspace_id": {
        "type": "string",
        "minLength": 1
      },
      "relative_path": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1024
      },
      "algorithm": {
        "type": "string",
        "const": "sha256",
        "default": "sha256"
      }
    },
    "additionalProperties": false
  }
}
