{
  "schema_version": "1.0",
  "name": "browser_network_errors",
  "description": "Read bounded failed-request and HTTP error evidence from a browser session.",
  "risk_level": 0,
  "timeout_seconds": 15,
  "idempotency": "read_only",
  "parameters": {
    "type": "object",
    "required": ["browser_session_id"],
    "properties": {
      "browser_session_id": {"type": "string", "format": "uuid"},
      "limit": {"type": "integer", "minimum": 1, "maximum": 1000, "default": 100}
    },
    "additionalProperties": false
  }
}
