{
  "schema_version": "1.0",
  "name": "list_processes",
  "description": "List bounded process summaries; command lines are opt-in and secret-masked.",
  "risk_level": 0,
  "timeout_seconds": 10,
  "idempotency": "read_only",
  "parameters": {
    "type": "object",
    "properties": {
      "name_contains": {
        "type": "string",
        "maxLength": 128
      },
      "include_command_line": {
        "type": "boolean",
        "default": false
      },
      "limit": {
        "type": "integer",
        "minimum": 1,
        "maximum": 500,
        "default": 100
      }
    },
    "additionalProperties": false
  }
}
