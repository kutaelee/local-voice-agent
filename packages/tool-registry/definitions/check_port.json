{
  "schema_version": "1.0",
  "name": "check_port",
  "description": "Check whether a TCP port is listening on the local machine.",
  "risk_level": 0,
  "timeout_seconds": 5,
  "idempotency": "read_only",
  "parameters": {
    "type": "object",
    "required": ["port"],
    "properties": {
      "host": {
        "type": "string",
        "enum": ["127.0.0.1", "localhost", "::1"],
        "default": "127.0.0.1"
      },
      "port": {
        "type": "integer",
        "minimum": 1,
        "maximum": 65535
      }
    },
    "additionalProperties": false
  }
}
