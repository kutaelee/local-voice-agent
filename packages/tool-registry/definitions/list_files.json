{
  "schema_version": "1.0",
  "name": "list_files",
  "description": "List a bounded directory tree inside an allowed workspace.",
  "risk_level": 0,
  "timeout_seconds": 15,
  "idempotency": "read_only",
  "parameters": {
    "type": "object",
    "required": ["workspace_id"],
    "properties": {
      "workspace_id": {
        "type": "string",
        "minLength": 1
      },
      "relative_path": {
        "type": "string",
        "maxLength": 1024,
        "default": "."
      },
      "max_depth": {
        "type": "integer",
        "minimum": 1,
        "maximum": 8,
        "default": 2
      },
      "limit": {
        "type": "integer",
        "minimum": 1,
        "maximum": 2000,
        "default": 500
      }
    },
    "additionalProperties": false
  }
}
