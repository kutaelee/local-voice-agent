{
  "schema_version": "1.0",
  "name": "extract_archive",
  "description": "Extract a hash-pinned ZIP into a new workspace directory with traversal and expansion limits.",
  "risk_level": 1,
  "timeout_seconds": 300,
  "idempotency": "required",
  "parameters": {
    "type": "object",
    "required": [
      "workspace_id",
      "archive_relative_path",
      "archive_sha256",
      "destination_relative_path",
      "destination_must_not_exist",
      "idempotency_key"
    ],
    "properties": {
      "workspace_id": {"type": "string", "minLength": 1},
      "archive_relative_path": {"type": "string", "minLength": 1, "maxLength": 1024},
      "archive_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
      "destination_relative_path": {"type": "string", "minLength": 1, "maxLength": 1024},
      "destination_must_not_exist": {"const": true},
      "max_entries": {"type": "integer", "minimum": 1, "maximum": 10000, "default": 1000},
      "max_expanded_bytes": {
        "type": "integer",
        "minimum": 1,
        "maximum": 2147483648,
        "default": 536870912
      },
      "idempotency_key": {"type": "string", "format": "uuid"}
    },
    "additionalProperties": false
  }
}
