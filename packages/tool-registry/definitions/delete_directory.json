{
  "schema_version": "1.0",
  "name": "delete_directory",
  "description": "Delete an empty workspace directory after exact per-execution approval.",
  "risk_level": 2,
  "timeout_seconds": 30,
  "idempotency": "required",
  "parameters": {
    "type": "object",
    "required": [
      "workspace_id",
      "relative_path",
      "must_be_empty",
      "approval_id",
      "idempotency_key"
    ],
    "properties": {
      "workspace_id": {"type": "string", "minLength": 1},
      "relative_path": {"type": "string", "minLength": 1, "maxLength": 1024},
      "must_be_empty": {"const": true},
      "approval_id": {"type": "string", "format": "uuid"},
      "idempotency_key": {"type": "string", "format": "uuid"}
    },
    "additionalProperties": false
  }
}
