{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local-voice-agent.invalid/schemas/approval-request.schema.json",
  "title": "Approval request",
  "type": "object",
  "required": [
    "schema_version",
    "approval_id",
    "session_id",
    "request_id",
    "tool_call_id",
    "tool_name",
    "risk_level",
    "normalized_arguments",
    "normalized_arguments_sha256",
    "precondition_version",
    "target",
    "expected_changes",
    "impact_scope",
    "rollback",
    "ordered_steps",
    "state",
    "created_at",
    "expires_at"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "approval_id": {"type": "string", "format": "uuid"},
    "session_id": {"type": "string", "format": "uuid"},
    "request_id": {"type": "string", "format": "uuid"},
    "tool_call_id": {"type": "string", "format": "uuid"},
    "tool_name": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
    "risk_level": {"type": "integer", "minimum": 1, "maximum": 2},
    "workspace_id": {"type": "string", "minLength": 1, "maxLength": 256},
    "normalized_arguments": {"type": "object"},
    "normalized_arguments_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "precondition_version": {"type": "integer", "minimum": 0},
    "target": {"type": "string", "minLength": 1, "maxLength": 4096},
    "expected_changes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": {"type": "string", "minLength": 1, "maxLength": 4096}
    },
    "impact_scope": {"type": "string", "minLength": 1, "maxLength": 4096},
    "rollback": {
      "type": "object",
      "required": ["possible", "steps"],
      "properties": {
        "possible": {"type": "boolean"},
        "steps": {
          "type": "array",
          "maxItems": 100,
          "items": {"type": "string", "minLength": 1, "maxLength": 4096}
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {"possible": {"const": true}},
            "required": ["possible"]
          },
          "then": {
            "properties": {"steps": {"minItems": 1}}
          }
        }
      ],
      "additionalProperties": false
    },
    "ordered_steps": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": {"type": "string", "minLength": 1, "maxLength": 4096}
    },
    "state": {"const": "PENDING"},
    "created_at": {"type": "string", "format": "date-time"},
    "expires_at": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": false
}
