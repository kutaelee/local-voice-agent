{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local-voice-agent.invalid/schemas/event-payloads.schema.json",
  "title": "Local Voice Agent event payload definitions",
  "$defs": {
    "_uuid": {
      "type": "string",
      "format": "uuid"
    },
    "_bounded_text": {
      "type": "string",
      "maxLength": 65536
    },
    "_audio_chunk": {
      "type": "object",
      "required": ["audio_stream_id", "chunk_index", "encoding", "data_base64"],
      "properties": {
        "audio_stream_id": {"$ref": "#/$defs/_uuid"},
        "chunk_index": {"type": "integer", "minimum": 0},
        "encoding": {"enum": ["pcm_s16le", "opus"]},
        "sample_rate_hz": {"type": "integer", "enum": [16000, 24000, 48000]},
        "channels": {"type": "integer", "enum": [1, 2]},
        "duration_ms": {"type": "integer", "minimum": 1, "maximum": 1000},
        "data_base64": {"type": "string", "contentEncoding": "base64", "maxLength": 524288}
      },
      "additionalProperties": false
    },
    "_tool_identity": {
      "type": "object",
      "required": ["tool_call_id", "tool_name"],
      "properties": {
        "tool_call_id": {"$ref": "#/$defs/_uuid"},
        "tool_name": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}
      }
    },
    "audio.input.start": {
      "type": "object",
      "required": ["audio_stream_id", "encoding", "sample_rate_hz", "channels"],
      "properties": {
        "audio_stream_id": {"$ref": "#/$defs/_uuid"},
        "encoding": {"enum": ["pcm_s16le", "opus"]},
        "sample_rate_hz": {"type": "integer", "enum": [16000, 24000, 48000]},
        "channels": {"type": "integer", "enum": [1, 2]}
      },
      "additionalProperties": false
    },
    "audio.input.chunk": {
      "$ref": "#/$defs/_audio_chunk"
    },
    "audio.input.end": {
      "type": "object",
      "required": ["audio_stream_id", "reason"],
      "properties": {
        "audio_stream_id": {"$ref": "#/$defs/_uuid"},
        "reason": {"enum": ["vad_end", "barge_in", "client_stop", "disconnect"]}
      },
      "additionalProperties": false
    },
    "transcript.user.partial": {
      "type": "object",
      "required": ["text", "language"],
      "properties": {
        "text": {"$ref": "#/$defs/_bounded_text"},
        "language": {"type": "string", "maxLength": 32},
        "stability": {"type": "number", "minimum": 0, "maximum": 1}
      },
      "additionalProperties": false
    },
    "transcript.user.final": {
      "type": "object",
      "required": ["text", "language"],
      "properties": {
        "text": {"$ref": "#/$defs/_bounded_text"},
        "language": {"type": "string", "maxLength": 32},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "audio_stream_id": {"$ref": "#/$defs/_uuid"}
      },
      "additionalProperties": false
    },
    "assistant.state": {
      "type": "object",
      "required": ["state"],
      "properties": {
        "state": {
          "enum": [
            "connecting",
            "listening",
            "recognizing",
            "thinking",
            "selecting_tool",
            "waiting_approval",
            "executing",
            "verifying",
            "synthesizing",
            "speaking",
            "interrupted",
            "switching_model",
            "reconnecting",
            "error"
          ]
        },
        "detail": {"type": "string", "maxLength": 1024}
      },
      "additionalProperties": false
    },
    "assistant.text.delta": {
      "type": "object",
      "required": ["text"],
      "properties": {
        "text": {"$ref": "#/$defs/_bounded_text"}
      },
      "additionalProperties": false
    },
    "assistant.text.final": {
      "type": "object",
      "required": ["text", "interrupted"],
      "properties": {
        "text": {"$ref": "#/$defs/_bounded_text"},
        "interrupted": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "audio.output.chunk": {
      "allOf": [
        {"$ref": "#/$defs/_audio_chunk"},
        {"required": ["sample_rate_hz", "channels"]}
      ]
    },
    "audio.output.end": {
      "type": "object",
      "required": ["audio_stream_id", "reason"],
      "properties": {
        "audio_stream_id": {"$ref": "#/$defs/_uuid"},
        "reason": {"enum": ["completed", "barge_in", "cancelled", "error"]}
      },
      "additionalProperties": false
    },
    "tool.plan": {
      "type": "object",
      "required": ["plan_id", "goal", "steps", "requires_approval"],
      "properties": {
        "plan_id": {"$ref": "#/$defs/_uuid"},
        "goal": {"type": "string", "minLength": 1, "maxLength": 4096},
        "requires_approval": {"type": "boolean"},
        "steps": {
          "type": "array",
          "minItems": 1,
          "maxItems": 50,
          "items": {
            "type": "object",
            "required": ["sequence", "summary", "risk_level"],
            "properties": {
              "sequence": {"type": "integer", "minimum": 1},
              "summary": {"type": "string", "minLength": 1, "maxLength": 2048},
              "tool_name": {"type": ["string", "null"], "pattern": "^[a-z][a-z0-9_]*$"},
              "risk_level": {"type": "integer", "minimum": 0, "maximum": 3}
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "tool.approval.required": {
      "type": "object",
      "required": [
        "approval_id",
        "tool_call_id",
        "tool_name",
        "risk_level",
        "target",
        "normalized_arguments",
        "arguments_digest",
        "expected_changes",
        "impact_scope",
        "rollback",
        "steps",
        "expires_at"
      ],
      "properties": {
        "approval_id": {"$ref": "#/$defs/_uuid"},
        "tool_call_id": {"$ref": "#/$defs/_uuid"},
        "tool_name": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
        "risk_level": {"type": "integer", "minimum": 1, "maximum": 3},
        "target": {"type": "string", "minLength": 1, "maxLength": 2048},
        "normalized_arguments": {"type": "object"},
        "arguments_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "expected_changes": {
          "type": "array",
          "maxItems": 100,
          "items": {"type": "string", "maxLength": 2048}
        },
        "impact_scope": {"type": "string", "maxLength": 4096},
        "rollback": {"type": "string", "maxLength": 4096},
        "steps": {
          "type": "array",
          "minItems": 1,
          "maxItems": 50,
          "items": {"type": "string", "maxLength": 2048}
        },
        "expires_at": {"type": "string", "format": "date-time"}
      },
      "additionalProperties": false
    },
    "tool.approval.response": {
      "type": "object",
      "required": ["approval_id", "decision", "arguments_digest"],
      "properties": {
        "approval_id": {"$ref": "#/$defs/_uuid"},
        "decision": {"enum": ["approve", "reject"]},
        "arguments_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "reason": {"type": "string", "maxLength": 2048}
      },
      "additionalProperties": false
    },
    "tool.started": {
      "allOf": [
        {"$ref": "#/$defs/_tool_identity"},
        {
          "type": "object",
          "required": ["started_at"],
          "properties": {
            "started_at": {"type": "string", "format": "date-time"}
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "tool.progress": {
      "allOf": [
        {"$ref": "#/$defs/_tool_identity"},
        {
          "type": "object",
          "required": ["stage", "summary"],
          "properties": {
            "stage": {"type": "string", "maxLength": 128},
            "summary": {"type": "string", "maxLength": 2048}
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "tool.completed": {
      "allOf": [
        {"$ref": "#/$defs/_tool_identity"},
        {
          "type": "object",
          "required": ["result", "evidence_ids"],
          "properties": {
            "result": {"type": "object"},
            "evidence_ids": {
              "type": "array",
              "maxItems": 100,
              "items": {"type": "string", "maxLength": 256}
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "tool.failed": {
      "allOf": [
        {"$ref": "#/$defs/_tool_identity"},
        {
          "type": "object",
          "required": ["error_code", "message", "rollback_available"],
          "properties": {
            "error_code": {"type": "string", "maxLength": 128},
            "message": {"type": "string", "maxLength": 4096},
            "rollback_available": {"type": "boolean"},
            "evidence_ids": {
              "type": "array",
              "maxItems": 100,
              "items": {"type": "string", "maxLength": 256}
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "tool.rollback.started": {
      "type": "object",
      "required": ["tool_call_id", "rollback_id"],
      "properties": {
        "tool_call_id": {"$ref": "#/$defs/_uuid"},
        "rollback_id": {"$ref": "#/$defs/_uuid"}
      },
      "additionalProperties": false
    },
    "tool.rollback.completed": {
      "type": "object",
      "required": ["tool_call_id", "rollback_id", "verified", "evidence_ids"],
      "properties": {
        "tool_call_id": {"$ref": "#/$defs/_uuid"},
        "rollback_id": {"$ref": "#/$defs/_uuid"},
        "verified": {"type": "boolean"},
        "evidence_ids": {
          "type": "array",
          "maxItems": 100,
          "items": {"type": "string", "maxLength": 256}
        }
      },
      "additionalProperties": false
    },
    "model.switch.started": {
      "type": "object",
      "required": ["from_model", "to_model", "phase"],
      "properties": {
        "from_model": {"type": ["string", "null"], "maxLength": 256},
        "to_model": {"type": "string", "minLength": 1, "maxLength": 256},
        "phase": {
          "enum": [
            "saving_state",
            "unloading",
            "loading",
            "health_checking",
            "generating",
            "restoring_default"
          ]
        }
      },
      "additionalProperties": false
    },
    "model.switch.completed": {
      "type": "object",
      "required": ["from_model", "to_model", "ready", "duration_ms"],
      "properties": {
        "from_model": {"type": ["string", "null"], "maxLength": 256},
        "to_model": {"type": "string", "minLength": 1, "maxLength": 256},
        "ready": {"type": "boolean"},
        "duration_ms": {"type": "number", "minimum": 0}
      },
      "additionalProperties": false
    },
    "operation.cancel.requested": {
      "type": "object",
      "required": [
        "target_kind",
        "target_id",
        "reason",
        "idempotency_key"
      ],
      "properties": {
        "target_kind": {
          "enum": [
            "assistant_response",
            "tool_execution",
            "agent_task",
            "model_switch"
          ]
        },
        "target_id": {"$ref": "#/$defs/_uuid"},
        "reason": {
          "enum": [
            "user_request",
            "barge_in",
            "app_background",
            "session_closing"
          ]
        },
        "idempotency_key": {"$ref": "#/$defs/_uuid"}
      },
      "additionalProperties": false
    },
    "operation.cancel.result": {
      "type": "object",
      "required": [
        "target_kind",
        "target_id",
        "status",
        "final_state",
        "summary"
      ],
      "properties": {
        "target_kind": {
          "enum": [
            "assistant_response",
            "tool_execution",
            "agent_task",
            "model_switch"
          ]
        },
        "target_id": {"$ref": "#/$defs/_uuid"},
        "status": {
          "enum": [
            "cancelled",
            "cancellation_requested",
            "not_cancellable",
            "already_terminal",
            "not_found"
          ]
        },
        "final_state": {"type": "string", "minLength": 1, "maxLength": 128},
        "summary": {"type": "string", "maxLength": 4096},
        "evidence_id": {"type": ["string", "null"], "maxLength": 256}
      },
      "additionalProperties": false
    },
    "error": {
      "type": "object",
      "required": ["error_code", "message", "component", "retryable"],
      "properties": {
        "error_code": {"type": "string", "minLength": 1, "maxLength": 128},
        "message": {"type": "string", "maxLength": 4096},
        "component": {"type": "string", "maxLength": 128},
        "retryable": {"type": "boolean"},
        "evidence_id": {"type": ["string", "null"], "maxLength": 256}
      },
      "additionalProperties": false
    }
  }
}
